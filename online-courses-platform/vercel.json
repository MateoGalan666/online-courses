{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/dist/**"
    }
  },
  "routes": [
    { "src": "/styles.css", "dest": "/frontend/styles.css" },
    { "src": "/images/(.*)", "dest": "/frontend/images/$1" },
    { "src": "/dist/(.*)", "dest": "/frontend/dist/$1" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/admin", "dest": "/frontend/admin.html" },
    { "src": "/checkout", "dest": "/frontend/checkout.html" },
    { "src": "/login", "dest": "/frontend/login.html" },
    { "src": "/estudiante", "dest": "/frontend/estudiante.html" },
    { "src": "/success", "dest": "/frontend/success.html" },
    { "src": "/curso/(.*)", "dest": "/frontend/curso.html" },
    { "src": "/", "dest": "/frontend/index.html" }
  ]
}
